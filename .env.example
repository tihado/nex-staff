# Database
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Auth
BETTER_AUTH_SECRET=replace-with-a-random-32-char-secret
# Optional locally. On Vercel, falls back to VERCEL_URL / VERCEL_BRANCH_URL / VERCEL_PROJECT_PRODUCTION_URL.
# BETTER_AUTH_URL=http://localhost:3000
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional — not used while email/password auth is enabled)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Google Gemini (Generative AI)
GOOGLE_GENERATIVE_AI_API_KEY=

# Cursor Cloud Agent (coder staff)
# CURSOR_API_KEY=
# CODER_GITHUB_REPO_URL=https://github.com/your-org/your-repo
# CODER_GITHUB_DEFAULT_BRANCH=main
# GITHUB_TOKEN=                 # Metadata Read; Pull requests Read/Write (merge)

# Cloudflare preview (coder staff deliverable preview link)
# CLOUDFLARE_API_TOKEN=          # Workers Scripts Read (+ Pages Read if using Pages)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_WORKER_NAME=nex-restacurant
# CLOUDFLARE_PAGES_PROJECT_NAME= # optional fallback for worker name; required for Pages preview

# Local dev: skip Vercel Sandbox OIDC and use in-memory workspace filesystem.
# Production/preview deploys must leave this unset (or false) and enable Sandbox OIDC on Vercel.
# SANDBOX_DISABLED=true

# Optional: override default model (gemini-3.5-flash)
# GEMINI_MODEL=
